                  "raw": "{\n  \"name\": \"{{roomName}}\"\n}"
                },
                "url": { "raw": "{{chatUrl}}/rooms", "host": ["{{chatUrl}}"], "path": ["rooms"] }
              }
            },
            {
              "name": "Create room (XML)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "pm.environment.set('roomNameXml', 'general-xml-' + Date.now());"
                    ],
                    "type": "text/javascript"
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('create room XML : 201 ou 409', () => pm.expect([201, 409]).to.include(pm.response.code));",
                      "pm.test('content-type XML', () => pm.expect(pm.response.headers.get('Content-Type')).to.match(/xml/));",
                      "if (pm.response.code === 201) {",
                      "  const m = pm.response.text().match(/<id>(\\d+)<\\/id>/);",
                      "  if (m) pm.environment.set('roomId', parseInt(m[1]));",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{tokenAlice}}" },
                  { "key": "Content-Type", "value": "application/xml" },
                  { "key": "Accept", "value": "application/xml" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<root>\n  <name>{{roomNameXml}}</name>\n</root>"
                },
                "url": { "raw": "{{chatUrl}}/rooms", "host": ["{{chatUrl}}"], "path": ["rooms"] }
              }
            },
            {
              "name": "List rooms (JSON)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('list rooms = 200', () => pm.response.to.have.status(200));",
                      "const j = pm.response.json();",
                      "pm.test('rooms est un tableau', () => pm.expect(j.rooms).to.be.an('array'));",
                      "if (!pm.environment.get('roomId') && j.rooms.length > 0) {",
