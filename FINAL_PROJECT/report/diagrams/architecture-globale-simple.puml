@startuml architecture-globale-simple
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam defaultFontName "Helvetica"
skinparam ranksep 30
skinparam nodesep 25

actor "Utilisateur" as user

[Frontend] as frontend

node "Fabrique de client" as factory

package "Phase 1 : SOAP" #LightBlue {
  [ChatService] as chatSoap
  [AuthService] as authSoap
  chatSoap -right-> authSoap : valide\nle jeton
}

package "Phase 2 : REST" #LightGreen {
  [ChatService] as chatRest
  [AuthService] as authRest
  chatRest -right-> authRest : valide\nle jeton
}

package "Bases de données" {
  package "SOAP" #LightBlue {
    database "auth_soap" as authSoapDb
    database "chat_soap" as chatSoapDb
  }
  package "REST" #LightGreen {
    database "auth_rest" as authRestDb
    database "chat_rest" as chatRestDb
  }
}

user --> frontend
frontend --> factory
factory --> chatSoap : si SOAP
factory --> chatRest : si REST

authSoap --> authSoapDb
chatSoap --> chatSoapDb
authRest --> authRestDb
chatRest --> chatRestDb

@enduml
